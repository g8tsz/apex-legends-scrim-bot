# Copy to .env for local development. Never commit the filled-in .env.
# See README.md for the full variable reference.

# HTTP listen address
ADDR=:8080

# Teams per lobby (use 3 for quick dev testing, 20 for production)
LOBBY_SIZE=20

# HMAC key for webhook authentication.
# SECURITY: override this in every production deployment. The server skips
# HMAC verification when WEBHOOK_SECRET is literally "dev-secret".
WEBHOOK_SECRET=change-me-in-production

# nhost GraphQL endpoint + admin secret
NHOST_GRAPHQL_URL=http://localhost:1337/v1/graphql
NHOST_ADMIN_SECRET=nhost-admin-secret

# Set to "true" to disable all external calls and use stub data.
DEV_MODE=false
